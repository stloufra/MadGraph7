"""Standalone driver for the MadGraph7 standalone_mg7 mode.

Orchestrates compilation and run of check_sa.exe in each SubProcesses/P*/ folder.

When invoked with no command-line options at all, the script exposes an
interactive interface: it lists the available backends and P* subfolders and asks
the user to pick one by number.
Option -f is still available to use default values for options.
"""

import argparse
import os
import subprocess
import sys

BACKENDS = ['cppauto', 'cppnone', 'cppsse4', 'cppavx2',
            'cpp512y', 'cpp512z', 'cuda', 'hip']

DEFAULT_BACKEND = 'cppauto'
# Defaults for the three positional check_sa.exe args:
# [#blocksPerGrid #threadsPerBlock] #iterations.
DEFAULT_CHECK_SA_ARGS = ['64', '256', '1']


def list_p_dirs(subproc):
    return sorted(d for d in os.listdir(subproc)
                  if d.startswith('P') and os.path.isdir(os.path.join(subproc, d)))


def prompt_choice(items, label, default_index=0):
    while True:
        print(f"\nSelect {label}:")
        for i, item in enumerate(items):
            tag = " (default)" if i == default_index else ""
            print(f"  [{i}] {item}{tag}")
        try:
            answer = input(f"Enter number [{default_index}]: ").strip()
        except EOFError:
            print()
            return items[default_index]
        if not answer:
            return items[default_index]
        if answer.isdigit() and 0 <= int(answer) < len(items):
            return items[int(answer)]
        print(f"Invalid choice: {answer!r}", file=sys.stderr)


def build_parser():
    parser = argparse.ArgumentParser(
        prog="generate_events",
        description="Build and run check_sa.exe in each SubProcesses/P*/ folder.",
        epilog=("With no options, the script prompts interactively for the "
                "backend and the P* subfolder. Pass -f to use defaults without "
                "prompting."),
    )
    parser.add_argument("-f", action="store_true", dest="force_defaults",
                        help="Use default options without prompting.")
    parser.add_argument("-b", "--backend", choices=BACKENDS, default=None,
                        metavar="BACKEND",
                        help=f"Backend to compile with (default: {DEFAULT_BACKEND}).")
    parser.add_argument("-p", "--proc", default=None, metavar="P_NAME",
                        help="P* subfolder to run, or 'all' (default: all).")
    parser.add_argument("-j", "--jobs", type=int, default=1,
                        help="Parallel make jobs (default: 1).")
    parser.add_argument("-l", "--list", action="store_true", dest="list_only",
                        help="List available P* subfolders and exit.")
    parser.add_argument("check_sa_args", nargs=argparse.REMAINDER,
                        help=f"Args forwarded to check_sa.exe "
                             f"(default: {' '.join(DEFAULT_CHECK_SA_ARGS)}). "
                             f"Use '--' to separate them from orchestrator options.")
    parser.add_argument("--cadna", choices=('Y', 'y', 'N', 'n'), default=None,
                        help="Enable CADNA analysis (Y/N).")
    parser.add_argument("--fptype", choices=('f', 'd', 'm'), default=None,
                        help="Floating-point type (f=both float, d=both double, m=mixed double/float).")
    return parser


def prompt_check_sa_args(default):
    """Prompt for the three check_sa.exe positional args on a single line.

    User types them as on the command line, e.g. "64 256 1".
    Missing values are filled from `default`, and an empty answer uses the full default.
    If the user enters 4+ tokens (5-arg form with json date/run) the whole line is passed through verbatim."""
    prompt = (f"\nEnter check_sa.exe args [#blocksPerGrid #threadsPerBlock] #iterations\n"
              f"  default: {' '.join(default)}\n"
              f"Values (or press Enter for default): ")
    try:
        answer = input(prompt).strip()
    except EOFError:
        print()
        return list(default)
    if not answer:
        return list(default)
    tokens = answer.split()
    if len(tokens) >= 4:
        return tokens
    result = list(default)
    for i, tok in enumerate(tokens):
        result[i] = tok
    return result


def prompt_yes_no(label, default=False):
    """Prompt for yes/no question. Returns True for yes, False for no."""
    default_str = 'Y' if default else 'N'
    while True:
        try:
            answer = input(f"\n{label} (Y/N) [{default_str}]: ").strip().lower()
        except EOFError:
            print()
            return default
        if not answer:
            return default
        if answer in ('y', 'yes'):
            return True
        if answer in ('n', 'no'):
            return False
        print(f"Invalid choice: {answer!r}. Please enter Y or N.", file=sys.stderr)


def prompt_fptype(items, default_index=0):
    """Prompt for fptype, accepting both index numbers (0,1,2) and letters (f,d,m)."""
    while True:
        print(f"\nSelect floating-point type (f/d/m):")
        for i, item in enumerate(items):
            tag = " (default)" if i == default_index else ""
            print(f"  [{i}] {item}{tag}")
        try:
            answer = input(f"Enter number or letter [{default_index}]: ").strip().lower()
        except EOFError:
            print()
            return items[default_index]
        if not answer:
            return items[default_index]
        if answer.isdigit() and 0 <= int(answer) < len(items):
            return items[int(answer)]
        if answer in items:
            return answer
        print(f"Invalid choice: {answer!r}", file=sys.stderr)



def resolve_proc(arg_proc, p_dirs):
    if arg_proc is None or arg_proc == 'all':
        return p_dirs
    if arg_proc in p_dirs:
        return [arg_proc]
    raise SystemExit(
        f"ERROR: P* '{arg_proc}' not found. Available: {', '.join(p_dirs)}"
    )


def main():
    parser = build_parser()
    args = parser.parse_args()
    interactive = (len(sys.argv) == 1)

    # Run from the process folder root regardless of where this is invoked from.
    os.chdir(os.path.dirname(os.path.dirname(os.path.realpath(__file__))))
    subproc = "SubProcesses"
    if not os.path.isdir(subproc):
        raise SystemExit(f"ERROR: {subproc} does not exist")

    p_dirs = list_p_dirs(subproc)
    if not p_dirs:
        raise SystemExit(f"ERROR: no P* subfolders found in {subproc}")

    if args.list_only:
        print(f"Available P* subfolders in {os.path.abspath(subproc)}:")
        for d in p_dirs:
            print(f"  {d}")
        return

    # Backend selection
    if args.backend is not None:
        backend = args.backend
    elif interactive:
        backend = prompt_choice(BACKENDS, 'backend', default_index=0)
    else:
        backend = DEFAULT_BACKEND

    # P* selection
    if args.proc is not None:
        chosen = resolve_proc(args.proc, p_dirs)
    elif interactive:
        choices = p_dirs + ['<all>']
        picked = prompt_choice(choices, 'P* subfolder', default_index=len(p_dirs))
        chosen = p_dirs if picked == '<all>' else [picked]
    else:
        chosen = p_dirs

    # check_sa args (forwarded). argparse.REMAINDER may include a leading '--'.
    extra = list(args.check_sa_args)
    if extra and extra[0] == '--':
        extra = extra[1:]
    if not extra:
        extra = (prompt_check_sa_args(DEFAULT_CHECK_SA_ARGS)
                 if interactive else list(DEFAULT_CHECK_SA_ARGS))

    # CADNA analysis
    if args.cadna is not None:
        cadna = args.cadna.lower() in ('y', 'yes')
    elif interactive:
        cadna = prompt_yes_no('Enable CADNA analysis?', default=False)
    else:
        cadna = False

    # CADNA is only supported with cppnone backend
    if cadna and backend != 'cppnone':
        raise SystemExit(
            f"ERROR: CADNA analysis is only supported with cppnone backend (selected: '{backend}')"
        )

    # CADNA_PATH validation
    if cadna:
        cadna_path = os.environ.get('CADNA_PATH')
        if not cadna_path:
            raise SystemExit(
                "\nERROR: CADNA analysis requires CADNA_PATH environment variable.\n"
                "Please install CADNA and set the environment variable:\n"
                "  export CADNA_PATH=/path/to/cadna/lib\n"
                "Then re-run the command."
            )
        if not os.path.isdir(cadna_path):
            raise SystemExit(
                f"\nERROR: CADNA_PATH='{cadna_path}' is not a valid directory."
            )

    cadna_flag = 'CADNA=1' if cadna else ''

    # FPTYPE (f=both float, d=both double, m=mixed double/float)
    fptype_choices = ['f', 'd', 'm']
    if args.fptype is not None:
        fptype = args.fptype
    elif interactive:
        fptype = prompt_fptype(fptype_choices, default_index=2)
    else:
        fptype = 'm'

    for d in chosen:
        path = os.path.join(subproc, d)
        print(f"\n=== [{backend}] Building {d} ===", flush=True)
        make_cmd = ['make', '-j', str(args.jobs), f'BACKEND={backend}', f'FPTYPE={fptype}', 'USEBUILDDIR=1']
        if cadna_flag:
            make_cmd.append(cadna_flag)
            make_cmd.append(f'CADNA_PATH={cadna_path}')
        subprocess.run(make_cmd, cwd=path, check=True)
        print(f"\n=== [{backend}] Running {d}/check_sa.exe {' '.join(extra)} ===", flush=True)
        subprocess.run(['./check_sa.exe', '-p', *extra], cwd=path, check=True)


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        pass
